{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDeleteAndOverwrite",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::BUCKET_NAME/*",
      "Condition": {
        "Null": {
          "s3:object-lock-mode": "false"
        }
      }
    },
    {
      "Sid": "RequireObjectLock",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::BUCKET_NAME/*",
      "Condition": {
        "StringNotEquals": {
          "s3:object-lock-mode": "COMPLIANCE"
        }
      }
    }
  ]
}
