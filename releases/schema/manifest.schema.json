{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Garudex-Labs/caracal/releases/schema/manifest.schema.json",
  "title": "Caracal release manifest",
  "type": "object",
  "required": ["release", "mode", "publishedAt", "binaries", "runtimeImage", "containers", "helm", "pypi", "npm"],
  "properties": {
    "release": {
      "type": "string",
      "pattern": "^v[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}(\\.[0-9]+)?(-rc\\..+)?$"
    },
    "mode": {
      "type": "string",
      "enum": ["rc", "stable"]
    },
    "publishedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "baseVersion": { "type": "string" },
    "suffix": { "type": "string" },
    "sha": { "type": "string" },
    "registries": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "binaries": {
      "type": "object",
      "required": ["shell", "console"],
      "additionalProperties": { "type": "string" }
    },
    "runtimeImage": { "type": "string" },
    "containers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    },
    "helm": {
      "type": "object",
      "required": ["chartVersion", "appVersion", "imageTag"],
      "properties": {
        "chartVersion": { "type": "string" },
        "appVersion": { "type": "string" },
        "imageTag": { "type": "string" }
      },
      "additionalProperties": false
    },
    "images": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "pypi": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "npm": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "githubRelease": {
      "type": "string",
      "format": "uri"
    }
  },
  "additionalProperties": false
}
