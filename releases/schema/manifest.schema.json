{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Garudex-Labs/caracal/releases/schema/manifest.schema.json",
  "title": "Caracal release manifest",
  "type": "object",
  "required": ["release", "mode", "binaries", "runtimeImage", "containers", "helm"],
  "properties": {
    "release": {
      "type": "string",
      "pattern": "^v[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}(\\.[0-9]+)?(-rc\\..+)?$"
    },
    "mode": {
      "type": "string",
      "enum": ["rc", "stable"]
    },
    "publishedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "version": { "type": "string" },
    "baseVersion": { "type": "string" },
    "suffix": { "type": "string" },
    "sha": { "type": "string" },
    "generatedAt": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "properties": {
        "gitSha": { "type": "string" },
        "dirty": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "registries": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "binaries": {
      "type": "object",
      "required": ["shell", "console"],
      "additionalProperties": { "type": "string" }
    },
    "runtimeImage": { "type": "string" },
    "containers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    },
    "helm": {
      "type": "object",
      "required": ["chartVersion", "appVersion", "imageTag"],
      "properties": {
        "chartVersion": { "type": "string" },
        "appVersion": { "type": "string" },
        "imageTag": { "type": "string" }
      },
      "additionalProperties": false
    },
    "images": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "pypi": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "npm": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "packages": {
      "type": "object",
      "required": ["published", "unchanged"],
      "properties": {
        "published": {
          "type": "object",
          "properties": {
            "pypi": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "npm": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "go": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "unchanged": {
          "type": "object",
          "properties": {
            "pypi": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "npm": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "go": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "githubRelease": {
      "oneOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "object",
          "required": ["tag", "assets"],
          "properties": {
            "tag": { "type": "string" },
            "assets": { "type": "string", "format": "uri" }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
