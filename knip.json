{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "tests/typescript/**/*.ts",
        "tests/shared/**/*.ts"
      ]
    }
  },
  "ignoreFiles": [
    "examples/**",
    "packages/engine/scripts/render-dev-env.mjs",
    "scripts/benchEnterprise.mjs",
    "scripts/validateFirstSuccess.mjs"
  ],
  "ignoreBinaries": ["build", "sync-embedded", "go", "python", "scripts/release.sh"],
  "ignoreDependencies": [
    "@changesets/runtime",
    "@caracalai/core",
    "@caracalai/engine",
    "@caracalai/oauth",
    "@caracalai/transport-mcp",
    "bun",
    "tsx"
  ]
}
