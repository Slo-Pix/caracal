        "label": "resource identifier",
        "input": "text",
        "advanced": true,
        "note": "Console generates this when blank.",
        "secret": false
      }
    ],
    "boundaries": [
      "Put target and routing values on the resource.",
      "Put upstream credential values on the provider.",
      "If the user needs a resource field not listed here, say it is unsupported and link the issue form."
    ],
    "not_supported_if_resource_requires": [
      "multiple upstream credential providers on one resource",
      "provider secrets on the resource form",
      "resource-specific OAuth client fields",
      "custom routing fields not visible in Console"
    ]
  },
  "issue_link": "https://github.com/Garudex-Labs/caracal/issues/new/choose"
