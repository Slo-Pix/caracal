{
  "purpose": "Ground truth for visible Caracal web console provider and resource fields.",
  "docs_lookup": {
    "caracal": "https://docs.caracal.run/guides/resources-providers/",
    "provider": "Use the official provider docs for the selected provider and flow."
  },
  "agent_rules": [
    "Use this file before mapping provider or resource fields.",
    "Expose only Caracal web console field labels from this file.",
    "Use docs only to explain a known Console field or provider term after matching the field label.",
    "If a provider requires a field or auth mode not listed here, say it is not currently supported.",
    "Send unsupported provider or resource needs to https://github.com/Garudex-Labs/caracal/issues/new/choose.",
    "Never repeat raw secrets."
  ],
  "output_contract": [
    "UI label",
    "Caracal web console field",
    "Meaning",
    "Required or optional",
    "Expected value",
    "Notes",
    "Secret handling"
  ],
  "unsupported_output_contract": [
    "Unsupported need",
    "Provider requirement",
    "Current Caracal web console support",
    "What to do",
    "Issue link"
  ],
  "provider_form": {
