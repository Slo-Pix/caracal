  "resource_form": {
    "form_title": "create resource",
    "field_source": "visible Console labels",
    "edit_form_label_aliases": [
      {
        "edit_label": "name",
        "same_as_create_label": "resource name"
      }
    ],
    "required_fields": [
      {
        "label": "resource name",
        "input": "text",
        "secret": false
      },
      {
        "label": "Caracal resource scopes",
        "input": "list",
        "format": "comma-separated",
        "secret": false
      },
      {
        "label": "upstream URL",
        "input": "text",
        "secret": false
      },
      {
        "label": "gateway application",
        "input": "picker or text",
        "secret": false
      },
      {
        "label": "upstream credential provider",
        "input": "picker or text",
        "secret": false
      }
    ],
    "optional_fields": [
