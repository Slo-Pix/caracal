{
  "name": "@caracalai/cli",
  "version": "0.1.1",
  "private": true,
  "description": "Caracal CLI: install, run, and manage the OSS agent identity stack.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "apps/cli"
  },
  "type": "module",
  "bin": {
    "caracal": "./bin/caracal.mjs"
  },
  "files": [
    "bin",
    "src"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "sync-embedded": "node scripts/build-embedded.mjs",
    "stamp:dev": "node scripts/stampDev.mjs",
    "stamp:release": "node scripts/stampRelease.mjs",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/caracal-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist/caracal-linux-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/index.ts --outfile dist/caracal-darwin-x64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/caracal-darwin-arm64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 src/index.ts --outfile dist/caracal-windows-x64.exe",
    "prebuild": "node scripts/stampDev.mjs && node scripts/build-embedded.mjs",
    "build": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64",
    "build:release": "node scripts/stampRelease.mjs && node scripts/buildLocalImages.mjs && bun run build",
    "dev": "node bin/caracal.mjs",
    "pretypecheck": "node scripts/stampDev.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. tests/typescript/unit/cli"
  },
  "dependencies": {
    "@caracalai/admin": "workspace:*",
    "@caracalai/core": "workspace:*",
    "@caracalai/oauth": "workspace:*",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
