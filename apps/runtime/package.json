{
  "name": "@caracalai/runtime",
  "version": "0.1.4-rc.1",
  "private": true,
  "description": "Caracal runtime shell for local stack lifecycle and workload execution.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "apps/runtime"
  },
  "type": "module",
  "bin": {
    "caracal": "./bin/caracal.mjs"
  },
  "files": [
    "bin",
    "src"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "sync-embedded": "pnpm --filter @caracalai/engine sync-embedded",
    "stamp:dev": "node scripts/stampDev.mjs",
    "stamp:release": "node scripts/stampRelease.mjs",
    "build:shell:linux-x64": "bun build --compile --target=bun-linux-x64 src/shell.ts --outfile dist/caracal-linux-x64",
    "build:shell:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/shell.ts --outfile dist/caracal-linux-arm64",
    "build:shell:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/shell.ts --outfile dist/caracal-darwin-x64",
    "build:shell:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/shell.ts --outfile dist/caracal-darwin-arm64",
    "build:shell:windows-x64": "bun build --compile --target=bun-windows-x64 src/shell.ts --outfile dist/caracal-windows-x64.exe",
    "compile:all": "bun run build:shell:linux-x64 && bun run build:shell:linux-arm64 && bun run build:shell:darwin-x64 && bun run build:shell:darwin-arm64 && bun run build:shell:windows-x64",
    "prebuild": "node scripts/stampDev.mjs",
    "build": "bun run compile:all",
    "build:release": "node scripts/stampRelease.mjs && pnpm --filter @caracalai/engine build && node scripts/buildLocalImages.mjs && bun run compile:all",
    "dev": "node bin/caracal.mjs",
    "pretypecheck": "node scripts/stampDev.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. tests/typescript/unit/runtime"
  },
  "dependencies": {
    "@caracalai/core": "workspace:*",
    "@caracalai/engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "bun": "1.3.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
