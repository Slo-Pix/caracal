{
  "name": "@caracalai/console",
  "version": "0.1.3-rc.1",
  "private": true,
  "description": "Caracal console UI: inspect and manage identity resources interactively.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "caracal-console": "./bin/caracal-console.mjs"
  },
  "files": [
    "bin",
    "src"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "stamp:dev": "node scripts/stampDev.mjs",
    "stamp:release": "node scripts/stampRelease.mjs",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/caracal-console-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist/caracal-console-linux-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/index.ts --outfile dist/caracal-console-darwin-x64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/caracal-console-darwin-arm64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 src/index.ts --outfile dist/caracal-console-windows-x64.exe",
    "compile:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64",
    "prebuild": "node scripts/stampDev.mjs",
    "build": "bun run compile:all",
    "build:release": "node scripts/stampRelease.mjs && bun run compile:all",
    "dev": "node bin/caracal-console-workspace.mjs",
    "pretypecheck": "node scripts/stampDev.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. tests/typescript/unit/console"
  },
  "dependencies": {
    "@caracalai/admin": "workspace:*",
    "@caracalai/engine": "workspace:*",
    "@caracalai/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
