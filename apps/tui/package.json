{
  "name": "@caracalai/tui",
  "version": "0.1.1",
  "private": true,
  "description": "Caracal terminal UI: inspect and manage the OSS agent identity stack interactively.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "caracal-tui": "./bin/caracal-tui.mjs"
  },
  "files": [
    "bin",
    "src"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/caracal-tui-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist/caracal-tui-linux-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/index.ts --outfile dist/caracal-tui-darwin-x64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/caracal-tui-darwin-arm64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 src/index.ts --outfile dist/caracal-tui-windows-x64.exe",
    "build": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64",
    "dev": "node bin/caracal-tui.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. tests/typescript/unit/tui"
  },
  "dependencies": {
    "@caracalai/admin": "workspace:*",
    "@caracalai/core": "workspace:*",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
