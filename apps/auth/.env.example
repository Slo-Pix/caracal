# Caracal, a product of Garudex Labs
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The auth service loads it automatically on `pnpm dev` / `pnpm start`.

# --- Core (optional; sensible localhost defaults already apply) ---
# CARACAL_AUTH_PORT=3002
# CARACAL_WEB_ORIGIN=http://localhost:3001

# --- Operator registration (authority boundary) ---
# A signed-in operator is proxied to the control plane with the shared global admin token, so
# registration must be restricted to trusted operators. Set an allowlist of emails and/or domain
# suffixes (comma-separated). Domain entries start with `@`. When set, only these may register.
#   CARACAL_OPERATOR_EMAILS=ops@example.com,@example.com
# Honours the `_FILE` secret convention (CARACAL_OPERATOR_EMAILS_FILE).
# With no allowlist, registration is open in development and closed in production. Override with:
#   CARACAL_OPEN_REGISTRATION=false

# --- Database & secret ---
# The auth service runs on PostgreSQL in every environment. `caracal web` points it at the
# dev stack's Postgres (started by `caracal up`) and provisions the signing secret
# automatically, so no configuration is needed for local development.
# For a standalone deployment, set a Postgres connection string and a signing secret:
#   CARACAL_AUTH_DATABASE_URL takes precedence; DATABASE_URL is the platform-wide fallback.
#   Both honour the `_FILE` secret convention (e.g. CARACAL_AUTH_DATABASE_URL_FILE).
#   The auth database is created automatically if the role may create databases.
# CARACAL_AUTH_DATABASE_URL=postgres://user:password@host:5432/caracal_auth
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CARACAL_AUTH_SECRET=change-me
# TLS posture for managed Postgres: "require" (verify cert) or "no-verify" (self-signed).
# CARACAL_AUTH_DATABASE_SSL=require

# --- Google sign-in ---
# Google Cloud Console -> Credentials -> OAuth client ID (Web application)
# Authorized redirect URI: http://localhost:3002/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub sign-in ---
# GitHub -> Settings -> Developer settings -> OAuth Apps
# Authorization callback URL: http://localhost:3002/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
