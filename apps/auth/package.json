{
  "name": "@caracalai/auth",
  "version": "0.1.6-rc.2",
  "private": true,
  "description": "Caracal Community Edition authentication service built on Better Auth.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "start": "node dist/server.js",
    "migrate": "node dist/migrate.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. tests/typescript/unit/auth",
    "lint": "eslint ."
  },
  "dependencies": {
    "@caracalai/core": "workspace:*",
    "@caracalai/engine": "workspace:*",
    "better-auth": "^1.3.4",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9.32.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "globals": "^15.15.0",
    "vitest": "^4.1.9"
  }
}
