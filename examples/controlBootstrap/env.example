#
# Shell-compatible environment example for the non-interactive Control API bootstrap.

# Copy to .env, fill in the values from Console, then source it:
#   cp env.example .env
#   $EDITOR .env
#   . .env
#   npm run bootstrap
#   npm run teardown
#
# Create the scoped control key once in Console (Control menu). Console returns
# a one-time client secret and the scopes the key may request. The key is
# zone-bound, application-only, and short-TTL. Never commit the secret.

# Optional: override the Control API surface. Defaults to http://127.0.0.1:8087.
# export CONTROL_URL="http://127.0.0.1:8087"

# Optional: override the STS token endpoint. Defaults to http://127.0.0.1:8080.
# export STS_URL="http://127.0.0.1:8080"

# Optional: override the Control resource audience. Defaults to caracal-control.
# export CONTROL_AUDIENCE="caracal-control"

# Scoped control key issued by Console.
export CONTROL_CLIENT_ID="app_pipernet_bootstrap"
export CONTROL_CLIENT_SECRET="replace-with-one-time-secret-from-console"

# Optional: override the requested scopes (space or comma separated). When unset
# the bootstrap requests the read/write/delete scopes it needs for provider,
# resource, and policy. The key still only receives scopes Console allowed it.
# export CONTROL_SCOPES="control:resource:write control:policy:write"

# Optional: requested token TTL in seconds (capped by the key max TTL).
# export CONTROL_TTL_SECONDS="300"
