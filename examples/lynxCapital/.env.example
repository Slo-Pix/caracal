# Required
OPENAI_API_KEY=sk-...

# Local provider infrastructure
LYNX_HOOK_BASE=http://127.0.0.1:8000

# REST provider URLs (point all 13 at the rest container in docker; or all at 127.0.0.1:8800 locally)
LYNX_MERCURY_URL=http://127.0.0.1:8800
LYNX_WISE_URL=http://127.0.0.1:8800
LYNX_STRIPE_URL=http://127.0.0.1:8800
LYNX_QB_URL=http://127.0.0.1:8800
LYNX_NETSUITE_URL=http://127.0.0.1:8800
LYNX_SAP_URL=http://127.0.0.1:8800
LYNX_OCR_URL=http://127.0.0.1:8800
LYNX_CLOSE_URL=http://127.0.0.1:8800
LYNX_REGULATORY_URL=http://127.0.0.1:8800
LYNX_BILLING_URL=http://127.0.0.1:8800
LYNX_TAX_URL=http://127.0.0.1:8800
LYNX_COMPLIANCE_URL=http://127.0.0.1:8800
LYNX_FX_URL=http://127.0.0.1:8800

# REST provider credentials
LYNX_MERCURY_KEY=local-mercury-bank-key
LYNX_WISE_KEY=local-wise-payouts-key
LYNX_STRIPE_KEY=local-stripe-treasury-key
LYNX_QB_KEY=local-quickbooks-key
LYNX_NETSUITE_KEY=local-netsuite-key
LYNX_SAP_KEY=local-sap-erp-key
LYNX_OCR_KEY=local-ocr-vision-key
LYNX_CLOSE_KEY=local-close-engine-key
LYNX_REGULATORY_KEY=local-regulatory-filings-key
LYNX_BILLING_KEY=local-customer-billing-key
LYNX_TAX_KEY=local-tax-rules-key
LYNX_COMPLIANCE_KEY=local-compliance-nexus-key
LYNX_FX_KEY=local-fx-rates-key

# Webhook signing secrets
LYNX_MERCURY_HOOK_SECRET=local-mercury-bank-secret
LYNX_WISE_HOOK_SECRET=local-wise-payouts-secret
LYNX_STRIPE_HOOK_SECRET=local-stripe-treasury-secret
LYNX_NETSUITE_HOOK_SECRET=local-netsuite-secret
LYNX_SAP_HOOK_SECRET=local-sap-erp-secret
LYNX_OCR_HOOK_SECRET=local-ocr-vision-secret
LYNX_CLOSE_HOOK_SECRET=local-close-engine-secret
LYNX_REGULATORY_HOOK_SECRET=local-regulatory-filings-secret
LYNX_BILLING_HOOK_SECRET=local-customer-billing-secret
LYNX_COMPLIANCE_HOOK_SECRET=local-compliance-nexus-secret
LYNX_TREASURY_HOOK_SECRET=local-treasury-ops-secret

# Streaming + gRPC + MCP
LYNX_FX_STREAM_URL=http://127.0.0.1:8810/v1/stream
LYNX_TREASURY_GRPC=127.0.0.1:50051
LYNX_TREASURY_KEY=local-treasury-ops-key
LYNX_COMPLIANCE_GRPC=127.0.0.1:50052
LYNX_MCP_HOST=127.0.0.1
LYNX_MCP_PORT=7800
LYNX_VENDOR_PORTAL_KEY=local-vendor-portal-key

# Caracal — required. Provision through `CARACAL_CONTROL_ENABLED=true caracal-tui`.
# Lynx reads caracal.toml and exchanges the control application client_secret
# for real STS access tokens.
CARACAL_COORDINATOR_URL=http://127.0.0.1:4000
CARACAL_GATEWAY_URL=http://127.0.0.1:8081
CARACAL_STS_URL=http://127.0.0.1:8080
