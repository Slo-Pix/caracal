# Required
OPENAI_API_KEY=sk-...

# Optional runtime configuration
# LYNX_CONFIG=config/company.yaml
# LYNX_SESSION_PATH=.lynx/session.json
# LYNX_REDIS_URL=redis://127.0.0.1:6379/0
# LYNX_PULSE_SYMBOL=USD/EUR
# LYNX_MAX_CONCURRENT_LLM=4          # cap simultaneous in-flight LLM streams
# LYNX_REQUIRE_APPROVAL=0            # 1 = pause irreversible ops for human approval
# LYNX_APPROVAL_TIMEOUT=300          # seconds to await an approval before denying
# LYNX_EVENT_LOG_DIR=.lynx/events    # set to persist per-run event logs for resumability

# Provider network health probe (any provider /healthz works)
LYNX_PROVIDER_HEALTH_URL=http://127.0.0.1:9400/healthz

# Webhook signing secrets (providers that emit async callbacks)
LYNX_HALCYON_HOOK_SECRET=local-halcyon-bank-secret
LYNX_MERIDIAN_HOOK_SECRET=local-meridian-pay-secret
LYNX_QUETZAL_HOOK_SECRET=local-quetzal-payouts-secret
LYNX_INKWELL_HOOK_SECRET=local-inkwell-ocr-secret
LYNX_BEACON_HOOK_SECRET=local-beacon-crm-secret

# Provider ecosystem (external-style partners, localhost ports 9400-9419).
# Base URLs are deterministic; credentials are generated per provider store.
# Print ready-to-source credential exports (the values below) with:
#   python -m _mock.providerlab.seedenv
#
# Each provider also needs ONE credential variable matching its auth type:
#   api_key / sdk providers   -> LYNX_PARTNER_<ID>_API_KEY
#   bearer_token / mcp-bearer -> LYNX_PARTNER_<ID>_TOKEN
#   oauth2 (cc and ac)        -> LYNX_PARTNER_<ID>_CLIENT_ID and _CLIENT_SECRET
#   none (internal)           -> no credential required
# Example (uncomment after running seedenv, or source its output directly):
#   LYNX_PARTNER_MERIDIAN_PAY_API_KEY=...
#   LYNX_PARTNER_SLATE_LEDGER_TOKEN=...
#   LYNX_PARTNER_CORDOBA_FX_CLIENT_ID=...
#   LYNX_PARTNER_CORDOBA_FX_CLIENT_SECRET=...
#   LYNX_PARTNER_PULSE_MARKET_API_KEY=...   # also enables the live SSE stream consumer
LYNX_PARTNER_HALCYON_BANK_URL=http://127.0.0.1:9400
LYNX_PARTNER_MERIDIAN_PAY_URL=http://127.0.0.1:9401
LYNX_PARTNER_CORDOBA_FX_URL=http://127.0.0.1:9402
LYNX_PARTNER_IRONBARK_ERP_URL=http://127.0.0.1:9403
LYNX_PARTNER_TALLYHALL_BOOKS_URL=http://127.0.0.1:9404
LYNX_PARTNER_SLATE_LEDGER_URL=http://127.0.0.1:9405
LYNX_PARTNER_INKWELL_OCR_URL=http://127.0.0.1:9406
LYNX_PARTNER_AEGIS_SCREENING_URL=http://127.0.0.1:9407
LYNX_PARTNER_VERAFIN_MONITOR_URL=http://127.0.0.1:9408
LYNX_PARTNER_LUMEN_IDENTITY_URL=http://127.0.0.1:9409
LYNX_PARTNER_BEACON_CRM_URL=http://127.0.0.1:9410
LYNX_PARTNER_ATLAS_VENDOR_URL=http://127.0.0.1:9411
LYNX_PARTNER_KEYSTONE_TREASURY_URL=http://127.0.0.1:9412
LYNX_PARTNER_SABRE_TAX_URL=http://127.0.0.1:9413
LYNX_PARTNER_QUETZAL_PAYOUTS_URL=http://127.0.0.1:9414
LYNX_PARTNER_VELA_NOTIFY_URL=http://127.0.0.1:9415
LYNX_PARTNER_CORE_BILLING_URL=http://127.0.0.1:9416
LYNX_PARTNER_RELAY_AUTOMATION_URL=http://127.0.0.1:9417
LYNX_PARTNER_PULSE_MARKET_URL=http://127.0.0.1:9418
LYNX_PARTNER_JUNCTION_PROCURE_URL=http://127.0.0.1:9419
