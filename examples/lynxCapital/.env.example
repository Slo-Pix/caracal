# Required
OPENAI_API_KEY=sk-...

# Mock infrastructure
LYNX_MOCK_FAST=0
LYNX_MOCK_STRICT_HOST=0
LYNX_HOOK_BASE=http://127.0.0.1:8000

# REST provider URLs (point all 13 at the rest container in docker; or all at 127.0.0.1:8800 locally)
LYNX_MERCURY_URL=http://127.0.0.1:8800
LYNX_WISE_URL=http://127.0.0.1:8800
LYNX_STRIPE_URL=http://127.0.0.1:8800
LYNX_QB_URL=http://127.0.0.1:8800
LYNX_NETSUITE_URL=http://127.0.0.1:8800
LYNX_SAP_URL=http://127.0.0.1:8800
LYNX_OCR_URL=http://127.0.0.1:8800
LYNX_CLOSE_URL=http://127.0.0.1:8800
LYNX_REGULATORY_URL=http://127.0.0.1:8800
LYNX_BILLING_URL=http://127.0.0.1:8800
LYNX_TAX_URL=http://127.0.0.1:8800
LYNX_COMPLIANCE_URL=http://127.0.0.1:8800
LYNX_FX_URL=http://127.0.0.1:8800

# REST provider credentials
LYNX_MERCURY_KEY=dev-mercury-bank-key
LYNX_WISE_KEY=dev-wise-payouts-key
LYNX_STRIPE_KEY=dev-stripe-treasury-key
LYNX_QB_KEY=dev-quickbooks-key
LYNX_NETSUITE_KEY=dev-netsuite-key
LYNX_SAP_KEY=dev-sap-erp-key
LYNX_OCR_KEY=dev-ocr-vision-key
LYNX_CLOSE_KEY=dev-close-engine-key
LYNX_REGULATORY_KEY=dev-regulatory-filings-key
LYNX_BILLING_KEY=dev-customer-billing-key
LYNX_TAX_KEY=dev-tax-rules-key
LYNX_COMPLIANCE_KEY=dev-compliance-nexus-key
LYNX_FX_KEY=dev-fx-rates-key

# Webhook signing secrets
LYNX_MERCURY_HOOK_SECRET=dev-mercury-bank-secret
LYNX_WISE_HOOK_SECRET=dev-wise-payouts-secret
LYNX_STRIPE_HOOK_SECRET=dev-stripe-treasury-secret
LYNX_NETSUITE_HOOK_SECRET=dev-netsuite-secret
LYNX_SAP_HOOK_SECRET=dev-sap-erp-secret
LYNX_OCR_HOOK_SECRET=dev-ocr-vision-secret
LYNX_CLOSE_HOOK_SECRET=dev-close-engine-secret
LYNX_REGULATORY_HOOK_SECRET=dev-regulatory-filings-secret
LYNX_BILLING_HOOK_SECRET=dev-customer-billing-secret
LYNX_COMPLIANCE_HOOK_SECRET=dev-compliance-nexus-secret
LYNX_TREASURY_HOOK_SECRET=dev-treasury-ops-secret

# Streaming + gRPC + MCP
LYNX_FX_STREAM_URL=http://127.0.0.1:8810/v1/stream
LYNX_TREASURY_GRPC=127.0.0.1:50051
LYNX_TREASURY_KEY=dev-treasury-ops-key
LYNX_COMPLIANCE_GRPC=127.0.0.1:50052
LYNX_MCP_HOST=127.0.0.1
LYNX_MCP_PORT=7800
LYNX_VENDOR_PORTAL_KEY=dev-vendor-portal-key

# Caracal — required. Install the Caracal CLI and run `caracal up` first.
CARACAL_COORDINATOR_URL=http://127.0.0.1:4000
CARACAL_ZONE_ID=lynx
CARACAL_APPLICATION_ID=lynx-capital
CARACAL_SUBJECT_TOKEN=dev-lynx-capital
CARACAL_GATEWAY_URL=http://127.0.0.1:8081
# Resource map (provider id → upstream). Loaded once at startup.
CARACAL_RESOURCES_FILE=config/caracal-resources.json
