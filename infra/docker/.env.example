#
# Local-dev environment template. Copy to `.env` and fill in values.

# ─── Required ────────────────────────────────────────────────────────────────
# All values below MUST be set before `docker compose up`.

# Postgres credentials. Used to build DATABASE_URL for every service.
POSTGRES_USER=caracal
POSTGRES_PASSWORD=
POSTGRES_DB=caracal

# Redis password. Used to build REDIS_URL for every service.
REDIS_PASSWORD=

# Admin bearer token used to authenticate `/v1/*` requests when provisioning
# zones and applications via `caracal zone create` / `caracal app create`.
CARACAL_ADMIN_TOKEN=

# 32-byte hex-encoded secrets. Generate each with: openssl rand -hex 32
ZONE_KEK=
AUDIT_HMAC_KEY=
STREAMS_HMAC_KEY=

# ─── Mode ────────────────────────────────────────────────────────────────────
# `dev` enables TLS-less inter-service calls and other escape hatches.
# End-user packaged installs use `stable` unless an rc binary sets `rc`.
CARACAL_MODE=dev

# Dev image tag. CLI-managed dev runs use <base>-dev.sha<gitsha>.
CARACAL_BASE_VERSION=2026.05.14
CARACAL_DEV_SHA=local
# CARACAL_DEV_VERSION=2026.05.14-dev.shalocal

# External-facing issuer URL advertised by STS in JWT `iss` and JWKS metadata.
# Default routes inter-service traffic over the compose network. Override with the
# public hostname when the stack is fronted by a reverse proxy or DNS name.
CARACAL_STS_ISSUER_URL=http://sts:8080

# ─── Optional: audit S3 export ───────────────────────────────────────────────
# Leave endpoint blank to disable Parquet export.
AUDIT_EXPORT_S3_ENDPOINT=
AUDIT_EXPORT_S3_BUCKET=
AUDIT_EXPORT_S3_REGION=us-east-1

# ─── Optional: container resource limits ─────────────────────────────────────
# Applied per app container (sts, api, gateway, audit, coordinator).
CARACAL_APP_CPU_LIMIT=1.0
CARACAL_APP_CPU_RESERVE=0.1
CARACAL_APP_MEM_LIMIT=512M
CARACAL_APP_MEM_RESERVE=128M

# Postgres. Tune POSTGRES_SHARED_BUFFERS ≈ 25% of CARACAL_DB_MEM_LIMIT.
CARACAL_DB_CPU_LIMIT=2.0
CARACAL_DB_MEM_LIMIT=1G
CARACAL_DB_MEM_RESERVE=256M
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_LOG_MIN_DURATION_MS=500

# Redis. REDIS_MAXMEMORY must be ≤ CARACAL_REDIS_MEM_LIMIT.
CARACAL_REDIS_CPU_LIMIT=1.0
CARACAL_REDIS_MEM_LIMIT=768M
CARACAL_REDIS_MEM_RESERVE=128M
REDIS_MAXMEMORY=512mb
