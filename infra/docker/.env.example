# Local-dev environment template. Copy to `.env` and fill in values.

POSTGRES_USER=caracal
POSTGRES_PASSWORD=changeMe
POSTGRES_DB=caracal

REDIS_PASSWORD=changeMe

CARACAL_ADMIN_TOKEN=changeMe

# Optional: S3-compatible endpoint for audit Parquet export (leave blank to disable)
AUDIT_EXPORT_S3_ENDPOINT=
AUDIT_EXPORT_S3_BUCKET=
