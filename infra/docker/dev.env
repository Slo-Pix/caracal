# Caracal, a product of Garudex Labs
#
# Dev defaults rendered from packages/engine/src/envSchema.ts. Do not edit by hand;
# run `node packages/engine/scripts/render-dev-env.mjs` after schema changes.
# Operator overrides live in infra/docker/local.env (gitignored).

# Deployment surface. `dev` enables build-from-source and bootstrap routes.
CARACAL_MODE=dev

# OCI registry prefix for caracal-* images. Must end with `/`.
CARACAL_REGISTRY=ghcr.io/garudex-labs/

# Dev base tag used to build local image names (<base>-dev.sha<sha>).
CARACAL_BASE_VERSION=2026.05.26

# Dev git sha embedded in locally built image tags.
CARACAL_DEV_SHA=local

# Postgres role used by every service.
POSTGRES_USER=caracal

# Postgres database name used by every service.
POSTGRES_DB=caracal

# shared_buffers tuning. Target ~25% of DB memory.
POSTGRES_SHARED_BUFFERS=256MB

# effective_cache_size planner hint.
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB

# work_mem per sort/hash op.
POSTGRES_WORK_MEM=8MB

# maintenance_work_mem for VACUUM/CREATE INDEX.
POSTGRES_MAINTENANCE_WORK_MEM=64MB

# max_connections ceiling.
POSTGRES_MAX_CONNECTIONS=100

# Slow query log threshold in ms.
POSTGRES_LOG_MIN_DURATION_MS=500

# Redis maxmemory ceiling. Must be ≤ CARACAL_REDIS_MEM_LIMIT.
REDIS_MAXMEMORY=512mb

# Public issuer URL advertised by STS in JWT `iss` and JWKS discovery. Set to your reverse-proxy hostname when fronted.
CARACAL_STS_ISSUER_URL=http://sts:8080

# S3 endpoint for Parquet export. Blank disables export.
AUDIT_EXPORT_S3_ENDPOINT=

# S3 bucket for Parquet export.
AUDIT_EXPORT_S3_BUCKET=

# S3 region for Parquet export.
AUDIT_EXPORT_S3_REGION=us-east-1

# OAuth2 `aud` claim the Control service requires on inbound tokens.
CONTROL_AUDIENCE=caracal-control

# Control service listen port.
CONTROL_PORT=8087

# Control service bind address inside the container.
CONTROL_HOST=0.0.0.0

# Token-bucket capacity per Control client.
CONTROL_RATE_CAPACITY=60

# Token-bucket window in seconds.
CONTROL_RATE_WINDOW_SEC=60

# JTI replay-cache TTL in seconds.
CONTROL_REPLAY_TTL_SEC=3600

# Per-app-container CPU limit.
CARACAL_APP_CPU_LIMIT=1.0

# Per-app-container CPU reservation.
CARACAL_APP_CPU_RESERVE=0.1

# Per-app-container memory limit.
CARACAL_APP_MEM_LIMIT=512M

# Per-app-container memory reservation.
CARACAL_APP_MEM_RESERVE=128M

# Postgres CPU limit.
CARACAL_DB_CPU_LIMIT=2.0

# Postgres memory limit.
CARACAL_DB_MEM_LIMIT=1G

# Postgres memory reservation.
CARACAL_DB_MEM_RESERVE=256M

# Redis CPU limit.
CARACAL_REDIS_CPU_LIMIT=1.0

# Redis memory limit.
CARACAL_REDIS_MEM_LIMIT=768M

# Redis memory reservation.
CARACAL_REDIS_MEM_RESERVE=128M

# OTLP collector endpoint. Blank disables traces/metrics export.
OTEL_EXPORTER_OTLP_ENDPOINT=

# Log verbosity for all services.
LOG_LEVEL=info
