{
  "name": "@caracalai/core",
  "version": "0.1.2",
  "description": "Caracal SDK foundation: logging, config, errors.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "packages/core/ts"
  },
  "keywords": [
    "caracal",
    "agent",
    "identity",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cliconfig.js",
      "types": "./dist/cliconfig.d.ts"
    },
    "./commands": {
      "import": "./dist/commands.js",
      "types": "./dist/commands.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../../.. tests/typescript/unit/shared",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
