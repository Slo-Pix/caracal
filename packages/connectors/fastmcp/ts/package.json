    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@caracalai/core": "0.1.5-rc.2",
    "@caracalai/transport-mcp": "0.1.5-rc.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
