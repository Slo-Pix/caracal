{
  "name": "@caracalai/identity",
  "version": "0.1.2",
  "description": "Caracal identity primitives: JWT verification, JWKS, scope, claims.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "packages/identity/ts"
  },
  "keywords": [
    "caracal",
    "identity",
    "jwt",
    "jwks"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../../.. tests/typescript/unit/identity",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@caracalai/core": "0.1.2",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
