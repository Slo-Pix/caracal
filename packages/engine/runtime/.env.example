# Caracal, a product of Garudex Labs
#
# End-user packaged environment. Seeded by `caracal up` on first install with
# random secrets. Do not edit by hand unless rotating keys.

# ─── Required (seeded automatically) ─────────────────────────────────────────

# Postgres credentials for the embedded Postgres container.
POSTGRES_USER=caracal
POSTGRES_PASSWORD=
POSTGRES_DB=caracal

# Redis password for the embedded Redis container.
REDIS_PASSWORD=

# Redis memory ceiling. Must not exceed available host memory. Default: 512mb.
REDIS_MAXMEMORY=512mb

# Admin bearer token. Used to authenticate `/v1/*` admin requests.
CARACAL_ADMIN_TOKEN=

# 32-byte hex-encoded secrets. Generated by `caracal up`.
ZONE_KEK=
AUDIT_HMAC_KEY=
STREAMS_HMAC_KEY=

# ─── Version and mode ────────────────────────────────────────────────────────
# Change only CARACAL_VERSION to select a published rc or stable image set.
CARACAL_VERSION=2026.05.14
# `stable` blocks dev escape hatches and bootstrap routes. End-user default.
CARACAL_MODE=stable

# ─── Optional: networking ────────────────────────────────────────────────────
# External URL advertised by STS in JWT `iss` claims and JWKS discovery.
# Set to your public hostname when the stack is fronted by a reverse proxy.
CARACAL_STS_ISSUER_URL=http://localhost:8080

# ─── Optional: audit S3 export ───────────────────────────────────────────────
AUDIT_EXPORT_S3_ENDPOINT=
AUDIT_EXPORT_S3_BUCKET=
AUDIT_EXPORT_S3_REGION=us-east-1

# ─── Optional: Control automation API ────────────────────────────────────────
# The Control service is OFF by default. Toggle it with `caracal control enable`
# / `caracal control disable` (or the TUI Control menu). When enabled, the next
# `caracal up` starts it on :8087 with OAuth2 JWT auth, JTI replay, per-resource
# scopes, and audit emission. CONTROL_AUDIENCE must match the `aud` claim minted
# by your OAuth2 client; leave the default unless you have a reason to change it.
CONTROL_AUDIENCE=caracal-control
