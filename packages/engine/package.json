{
  "name": "@caracalai/engine",
  "version": "0.1.2",
  "private": true,
  "description": "Shared execution engine for the Caracal CLI and TUI: process control, stack lifecycle, runtime install, and OAuth step-up.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "packages/engine"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cliconfig.js",
      "types": "./dist/cliconfig.d.ts"
    },
    "./commands": {
      "import": "./dist/commands.js",
      "types": "./dist/commands.d.ts"
    },
    "./crash": {
      "import": "./dist/crash.js",
      "types": "./dist/crash.d.ts"
    },
    "./scrubCwdEnv": {
      "import": "./dist/scrubCwdEnv.js",
      "types": "./dist/scrubCwdEnv.d.ts"
    }
  },
  "files": [
    "dist",
    "runtime"
  ],
  "scripts": {
    "sync-embedded": "node scripts/build-embedded.mjs",
    "prebuild": "node scripts/build-embedded.mjs",
    "build": "tsc",
    "pretypecheck": "node scripts/build-embedded.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@caracalai/admin": "workspace:*",
    "@caracalai/core": "workspace:*",
    "@caracalai/oauth": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3"
  }
}
