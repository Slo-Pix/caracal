{
  "name": "@caracalai/sdk",
  "version": "0.1.5-rc.2",
  "description": "Caracal agent identity and delegation SDK.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "packages/sdk/ts"
  },
  "keywords": [
    "caracal",
    "agent",
    "identity",
    "delegation",
    "sdk"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./advanced": {
      "import": "./dist/advanced.js",
      "types": "./dist/advanced.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@caracalai/oauth": "0.1.5-rc.2",
    "smol-toml": "^1.4.2"
  },
  "scripts": {
    "build": "pnpm --dir ../../oauth/ts build && tsc",
    "typecheck": "pnpm --dir ../../oauth/ts build && tsc --noEmit",
    "test": "vitest run --root ../../.. tests/typescript/unit/sdk/client.test.ts tests/typescript/unit/sdk/http.test.ts tests/typescript/unit/sdk/context.test.ts tests/typescript/unit/sdk/primitives.test.ts",
    "prepublishOnly": "pnpm --dir ../../oauth/ts build && tsc"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
