{
  "name": "@caracalai/admin",
  "version": "0.1.5-rc.3",
  "description": "Typed Caracal admin API client.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "packages/admin/ts"
  },
  "keywords": [
    "caracal",
    "admin",
    "api",
    "client"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "pnpm run clean",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../../.. tests/typescript/unit/admin",
    "prepublishOnly": "pnpm run clean && tsc"
  },
  "dependencies": {
    "@caracalai/core": "0.1.5-rc.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
