{
  "name": "@caracalai/oauth",
  "version": "0.1.5-rc.1",
  "description": "Caracal RFC 8693 OAuth 2.0 token exchange client.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Garudex-Labs/caracal",
  "repository": {
    "type": "git",
    "url": "https://github.com/Garudex-Labs/caracal.git",
    "directory": "packages/oauth/ts"
  },
  "keywords": [
    "caracal",
    "oauth",
    "token-exchange",
    "rfc8693"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
