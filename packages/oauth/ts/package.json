  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../../.. tests/typescript/unit/sdk/oauth",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@caracalai/core": "0.1.5-rc.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
