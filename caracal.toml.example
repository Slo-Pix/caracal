# Caracal, a product of Garudex Labs
#
# Example configuration for Caracal runtime injection and SDK clients.

# STS endpoint used by caracal run for OAuth token exchange.
zone_url = "http://localhost:8080"

# SDK-only aliases. The runtime ignores these fields, but Python SDK
# Caracal.from_config() can read them when the same file is mounted into apps.
sts_url = "http://localhost:8080"
coordinator_url = "http://localhost:4000"
gateway_url = "http://localhost:8081"

# Zone and confidential application created in the Console.
zone_id = "zone_from_console"
application_id = "app_from_console"
app_client_secret = "secret_from_console"

# Runtime behavior for optional credential failures.
continue_on_failure = false

# Required credentials. caracal run injects each token into env; SDKs can also
# use upstream_prefix as a resource binding for Gateway-routed provider calls.
[[credentials]]
env = "RESOURCE_TOKEN"
resource = "resource://local-http"
upstream_prefix = "https://api.example.internal/"

# Optional credentials let local tools start when a non-critical resource token
# cannot be acquired.
[[optional_credentials]]
env = "OPTIONAL_RESOURCE_TOKEN"
resource = "resource://optional-http"
upstream_prefix = "https://optional.example.internal/"
on_failure = "warn"

# Runtime governance for subprocesses that launch MCP servers directly.
[mcp_governance]
mode = "block"
