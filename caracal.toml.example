#
# Runtime profile reference for Caracal token injection and SDK clients.

# Generate real values from Console first-setup instead of copying this file
# into an onboarding path. The Console result creates a profile from the zone,
# application, resource, policy, and secret-file path that you just configured.

# Required runtime fields generated by Console:
# zone_url
# zone_id
# application_id
# app_client_secret_file

# SDK-readable aliases that may appear in generated profiles:
# sts_url
# coordinator_url
# gateway_url

# Runtime behavior:
# continue_on_failure = false

# Required credential entries are generated from real resource IDs:
# [[credentials]]
# env
# resource
# upstream_prefix

# Optional credential entries are advanced runtime configuration:
# [[optional_credentials]]
# env
# resource
# on_failure = "warn"

# MCP subprocess governance:
# [mcp_governance]
# mode = "block"
