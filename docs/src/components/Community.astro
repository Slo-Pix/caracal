---

<section class="community" aria-labelledby="community-heading">
  <div class="community__inner">
    <h2 id="community-heading" class="community__heading">
      <span class="community__heading-lead">Join the community</span>
      <span class="community__heading-name">Build with us</span>
    </h2>
    <p class="community__lede">
      Caracal is built in the open. Ask questions, file issues, and shape the roadmap.
    </p>

    <div class="community__grid">
      <a class="community__card" href="https://github.com/Garudex-Labs/caracal" target="_blank" rel="noreferrer noopener">
        <span class="community__card-glyph" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
            <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.12-1.47-1.12-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.08.63-1.33-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.55 9.55 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2Z" />
          </svg>
        </span>
        <h3 class="community__card-title">GitHub</h3>
        <p class="community__card-body">
          Source, issues, and pull requests. Star the repo to follow releases.
        </p>
        <span class="community__card-cta">Garudex-Labs/caracal →</span>
      </a>

      <a class="community__card" href="https://discord.gg/" target="_blank" rel="noreferrer noopener">
        <span class="community__card-glyph" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
            <path d="M20.32 5.36A17.5 17.5 0 0 0 16.13 4l-.21.4a14.6 14.6 0 0 1 4.05 2.06A14.84 14.84 0 0 0 4 6.46 14.6 14.6 0 0 1 8.07 4.4L7.87 4a17.5 17.5 0 0 0-4.19 1.36C1.05 9.6.18 13.74.61 17.83a17.7 17.7 0 0 0 5.4 2.74l.43-.6a11.6 11.6 0 0 1-1.83-.89l.45-.32a12.5 12.5 0 0 0 11.88 0l.45.32c-.58.34-1.2.64-1.83.89l.43.6a17.7 17.7 0 0 0 5.4-2.74c.5-4.74-.6-8.83-2.07-12.47ZM8.5 15.5a1.97 1.97 0 0 1-1.83-2.06A1.95 1.95 0 0 1 8.5 11.4a1.95 1.95 0 0 1 1.83 2.04 1.96 1.96 0 0 1-1.83 2.06Zm7 0a1.97 1.97 0 0 1-1.83-2.06 1.95 1.95 0 0 1 1.83-2.04 1.94 1.94 0 0 1 1.83 2.04 1.95 1.95 0 0 1-1.83 2.06Z" />
          </svg>
        </span>
        <h3 class="community__card-title">Discord</h3>
        <p class="community__card-body">
          Real-time chat with maintainers and other operators. Share what you build.
        </p>
        <span class="community__card-cta">Join the server →</span>
      </a>

      <a class="community__card" href="/resources/contributing/">
        <span class="community__card-glyph" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="3.5" />
            <path d="M5 21a7 7 0 0 1 14 0" />
            <path d="m17 11 1.5 1.5L22 9" />
          </svg>
        </span>
        <h3 class="community__card-title">Contribute</h3>
        <p class="community__card-body">
          Roadmap, contribution guide, and good-first-issue list for new contributors.
        </p>
        <span class="community__card-cta">Start contributing →</span>
      </a>
    </div>
  </div>
</section>
