 * Action buttons to copy the current page as Markdown or open in an AI assistant.
 */

const pageUrl = Astro.url.href
const pageTitle = Astro.url.pathname
---

<aside class="ai-actions">
  <button
    class="ai-action-btn"
    data-llms-full-url="/llms-full.txt"
    data-page-url={pageUrl}
    id="copy-as-markdown"
  >
    Copy as Markdown
  </button>
  <a
    class="ai-action-btn"
    href={`https://claude.ai/new?q=${encodeURIComponent(`Using the Caracal documentation at ${pageUrl}, explain ${pageTitle}`)}`}
    target="_blank"
    rel="noopener noreferrer"
  >
    Open in Claude
  </a>
  <a
    class="ai-action-btn"
    href={`https://chatgpt.com/?q=${encodeURIComponent(`Using the Caracal documentation at ${pageUrl}, explain ${pageTitle}`)}`}
    target="_blank"
    rel="noopener noreferrer"
  >
    Open in ChatGPT
  </a>
</aside>

<script>
  const btn = document.getElementById('copy-as-markdown')
  if (btn) {
    btn.addEventListener('click', async () => {
      const llmsUrl = btn.dataset.llmsFullUrl!
      const pageUrl = btn.dataset.pageUrl!
      const text = await fetch(llmsUrl).then((r) => r.text())
      const marker = `# URL: ${pageUrl}`
      const start = text.indexOf(marker)
      if (start === -1) {
        await navigator.clipboard.writeText(text)
        return
      }
      const nextSep = text.indexOf('\n---\n', start + marker.length)
      const section = nextSep === -1 ? text.slice(start) : text.slice(start, nextSep)
      await navigator.clipboard.writeText(section)
    })
  }
</script>
