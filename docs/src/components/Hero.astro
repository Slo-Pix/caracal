---
/**
 * Copyright (C) 2026 Garudex Labs.  All Rights Reserved.
 * Caracal, a product of Garudex Labs
 *
 * Custom hero override for the docs landing page.
 */
import Default from '@astrojs/starlight/components/Hero.astro'

const route = (Astro.locals as any)?.starlightRoute
const data = route?.entry?.data ?? {}
const hero = data.hero as
  | undefined
  | {
      eyebrow?: string
      title?: string
      tagline?: string
      actions?: Array<{ text: string; link: string; variant?: 'primary' | 'secondary' }>
    }

const useCustom = !!hero && data.template === 'splash'
const title = hero?.title ?? data.title ?? ''
const tagline = hero?.tagline ?? data.description ?? ''
const eyebrow = hero?.eyebrow ?? 'Caracal'
const actions = hero?.actions ?? []
---

{
  useCustom ? (
    <section id="home" class="landing-hero" aria-label="Caracal documentation hero">
      <div class="landing-hero__content">
        <p class="landing-hero__eyebrow">{eyebrow}</p>
        <h1 class="landing-hero__title" set:html={title} />
        <p class="landing-hero__tagline">{tagline}</p>
        {actions.length > 0 && (
          <div class="landing-hero__actions">
            {actions.map((a) => (
              <a
                class={`landing-button landing-button--${a.variant ?? 'secondary'}`}
                href={a.link}
              >
                {a.text}
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  ) : (
    <Default />
  )
}
