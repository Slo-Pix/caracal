---
/*
 * Copyright (C) 2026 Garudex Labs.  All Rights Reserved.
 * Caracal, a product of Garudex Labs
 *
 * Landing footer with community and enterprise links plus a live repository star count.
 */

const repo = "https://github.com/Garudex-Labs/caracal";

let stars: number | null = null;
try {
  const res = await fetch("https://api.github.com/repos/Garudex-Labs/caracal", {
    headers: { Accept: "application/vnd.github+json", "User-Agent": "caracal-docs" },
  });
  if (res.ok) {
    const data = await res.json();
    if (typeof data.stargazers_count === "number") stars = data.stargazers_count;
  }
} catch {
  stars = null;
}

const starLabel =
  stars === null
    ? null
    : stars >= 1000
      ? `${(stars / 1000).toFixed(1).replace(/\.0$/, "")}k`
      : String(stars);
---

<footer class="landing-footer" role="contentinfo">
  <div class="landing-footer__panel">
    <div class="landing-footer__inner">

      <!-- Brand -->
      <div class="landing-footer__brand">
        <p class="landing-footer__title">Caracal</p>
        <p class="landing-footer__tag">Authority infrastructure for agents and services.</p>

        <a class="landing-footer__stars" href={repo} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M12 17.27 6.18 21l1.64-7.03L2 8.91l7.19-.61L12 1l2.81 7.3 7.19.61-5.82 5.06L17.82 21z" />
          </svg>
          <span>Star on GitHub</span>
          {starLabel && <span class="landing-footer__stars-count">{starLabel}</span>}
        </a>

        <div class="landing-footer__social">
          <a href={repo} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.41 7.86 10.94.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.37-3.87-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.21 1.79 1.21 1.04 1.79 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.42.36.8 1.08.8 2.18v3.23c0 .31.21.68.8.56A11.52 11.52 0 0 0 23.5 12.02C23.5 5.74 18.27.5 12 .5Z" />
            </svg>
          </a>
          <a href="https://discord.gg/jdstP2cxEZ" target="_blank" rel="noopener noreferrer" aria-label="Discord">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M20.32 4.37A19.8 19.8 0 0 0 15.45 3a13.6 13.6 0 0 0-.62 1.27 18.3 18.3 0 0 0-5.66 0A13 13 0 0 0 8.54 3a19.7 19.7 0 0 0-4.87 1.37C.58 9 .06 13.45.32 17.85a19.9 19.9 0 0 0 6 3.04q.73-.99 1.28-2.1c-.7-.26-1.37-.58-2.01-.96q.26-.18.5-.38a14.2 14.2 0 0 0 12.13 0q.25.21.5.38c-.64.38-1.32.7-2.02.96q.56 1.11 1.28 2.1a19.8 19.8 0 0 0 6.01-3.04c.31-5.1-.52-9.51-3.45-13.48ZM8.3 15.14c-1.18 0-2.15-1.08-2.15-2.4s.95-2.41 2.15-2.41 2.17 1.09 2.15 2.41c0 1.32-.95 2.4-2.15 2.4Zm7.4 0c-1.18 0-2.15-1.08-2.15-2.4s.95-2.41 2.15-2.41 2.17 1.09 2.15 2.41c0 1.32-.94 2.4-2.15 2.4Z" />
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/caracal-run" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Enterprise -->
      <div class="landing-footer__col">
        <p class="landing-footer__col-title">Enterprise</p>
        <a href="https://cal.com/rawx18/caracal-enterprise-sales" target="_blank" rel="noopener noreferrer">Book a call</a>
        <a href="/enterprise/">Enterprise overview</a>
      </div>

      <!-- Community -->
      <div class="landing-footer__col">
        <p class="landing-footer__col-title">Community</p>
        <a href={repo} target="_blank" rel="noopener noreferrer">GitHub repository</a>
        <a href="https://discord.gg/xB3xVVzcvk" target="_blank" rel="noopener noreferrer">Weekly Dev Call · Thu 9pm IST</a>
      </div>

    </div>

    <div class="landing-footer__bar">
      <p>© 2026 Garudex Labs. All rights reserved.</p>
      <p>Caracal Open Source Edition is Apache-2.0 licensed.</p>
    </div>

    <div class="landing-footer__wordmark" aria-hidden="true">
      <span>Caracal</span>
    </div>
  </div>
</footer>
