 *
 * Environment variable reference table with per-row deep-link IDs.
 */

type ServiceName = 'sts' | 'gateway' | 'coordinator' | 'audit' | 'all'

interface EnvVar {
  name: string
  description: string
  default?: string
  required: boolean
  service: ServiceName
  example?: string
}

interface Props {
  vars: EnvVar[]
}

const { vars } = Astro.props
---

<table class="env-var-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Required</th>
      <th>Default</th>
      <th>Service</th>
      <th>Description</th>
      <th>Example</th>
    </tr>
  </thead>
  <tbody>
    {vars.map((v) => (
      <tr id={v.name}>
        <td><code>{v.name}</code></td>
        <td>{v.required ? 'Yes' : 'No'}</td>
        <td>{v.default ?? '—'}</td>
        <td>{v.service}</td>
        <td>{v.description}</td>
        <td>{v.example ? <code>{v.example}</code> : '—'}</td>
      </tr>
    ))}
  </tbody>
</table>
